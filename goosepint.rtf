"\\"Working.\\"",\
"\\"Need to walk the dog.\\"",\
"\\"No valid excuse located.\\"",\
"\\"Still reviewing the calendar.\\""\
];\
\
function updateExcuse()\{\
\
document.getElementById("excuse").innerText=\
excuses[Math.floor(Math.random()*excuses.length)];\
\
\}\
\
updateExcuse();\
\
setInterval(updateExcuse,5000);\
\
